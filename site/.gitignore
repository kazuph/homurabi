# Site-local Bundler / Wrangler artifacts (the root .gitignore covers
# repo-wide patterns; this file is the canonical app's own slice).
.bundle/
vendor/bundle/
node_modules/
.wrangler/
.dev.vars

# Opal build outputs (keep generated Workers entry tracked for wrangler main)
build/**
!build/worker.entrypoint.mjs
dist/
*.opal.js
*.opal.mjs

# Local secrets / per-machine config
.env
.env.local
.mise.local.toml
Gemfile.lock.local
.ruby-version.local

# Local task artifacts (report/evidence, do not version)
.artifacts/
.playwright-cli/
