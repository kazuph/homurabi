#!/usr/bin/env ruby
# frozen_string_literal: true
#
# Phase 12 — Compile Sequel `migration do ... end` DSL files into
# plain SQL `.sql` files that `wrangler d1 migrations apply` can
# consume directly.
#
# This script runs under **CRuby** (never Opal / Workers) so it can
# leverage the full Sequel migration runner against an in-memory
# SQLite database, then capture the SQL that would have been sent.
#
# Usage:
#   bin/homurabi-migrate compile <migrations_dir> [--out <dir>]
#   bin/homurabi-migrate compile db/migrations
#   bin/homurabi-migrate compile db/migrations --out migrations
#
# The produced .sql files live under <out>/ and are named
# `NNNN_<migration-basename>.sql`, matching wrangler's expectation.
#
# Requirements:
#   - A CRuby with `sequel` and `sqlite3` gems available
#   - Run via `bundle exec bin/homurabi-migrate ...` if your Gemfile
#     pins `sqlite3`; otherwise `gem install sequel sqlite3` first.

require 'fileutils'
require 'optparse'
require 'logger'

cmd = ARGV.shift
unless cmd == 'compile'
  warn 'Usage: bin/homurabi-migrate compile <migrations_dir> [--out <dir>]'
  exit 1
end

migrations_dir = ARGV.shift
unless migrations_dir && File.directory?(migrations_dir)
  warn "ERROR: migrations_dir '#{migrations_dir}' not found"
  exit 1
end

out_dir = migrations_dir
OptionParser.new do |o|
  o.on('--out DIR', 'Output directory for compiled SQL files') { |v| out_dir = v }
end.parse!(ARGV)
FileUtils.mkdir_p(out_dir)

begin
  require 'sequel'
  Sequel.extension :migration
rescue LoadError
  warn 'ERROR: `sequel` gem is required. Install via `gem install sequel sqlite3`.'
  exit 1
end
begin
  require 'sqlite3'
rescue LoadError
  warn 'ERROR: `sqlite3` gem is required.'
  exit 1
end

# Discover migrations. Sequel sorts by numeric prefix or timestamp.
migration_files = Dir.glob(File.join(migrations_dir, '*.rb')).sort

if migration_files.empty?
  warn "ERROR: no .rb migration files found in #{migrations_dir}"
  exit 1
end

# For each migration, run it against an in-memory SQLite database
# with SQL logging enabled; capture the emitted SQL.
# NOTE: migrations are run in isolation (one per fresh in-memory DB)
# so that naive `change do ... end` definitions don't accidentally
# rely on schema from earlier migrations in the same compile run.
migration_files.each_with_index do |rb, idx|
  base = File.basename(rb, '.rb')
  number = (base =~ /\A(\d+)_/) ? Regexp.last_match(1) : format('%04d', idx + 1)

  captured = []
  db = Sequel.sqlite(logger: Logger.new(nil))
  db.sql_log_level = :info

  # Hook SQL capture. `define_singleton_method` allows yielding to
  # the caller's block via `blk.call`; `yield` inside the proc
  # body would refer to the outer scope's yield (there is none
  # here), hence the explicit proc parameter.
  sqls = captured
  db.define_singleton_method(:log_connection_yield) do |sql, _conn, *, &blk|
    sqls << sql unless sql.strip.start_with?('PRAGMA')
    blk.call
  end

  # Seed: run all prior migrations so the target sees the up-to-date schema
  migration_files[0...idx].each do |prev|
    migration = eval(File.read(prev), binding, prev)
    migration.apply(db, :up)
  end

  # Re-seed capture (ignore prior-seed SQL)
  sqls.clear

  migration = eval(File.read(rb), binding, rb)
  migration.apply(db, :up)

  out_path = File.join(out_dir, "#{number}_#{base.sub(/\A\d+_/, '')}.sql")
  File.write(out_path, captured.map { |s| "#{s};" }.join("\n") + "\n")
  puts "→ #{out_path} (#{captured.size} statement#{'s' if captured.size != 1})"
end

puts
puts "✓ Compiled #{migration_files.size} migration(s) to #{out_dir}/"
puts '  Apply with: wrangler d1 migrations apply homurabi-db [--local]'
