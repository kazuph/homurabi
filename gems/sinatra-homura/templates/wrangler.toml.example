# Example wrangler.toml for a minimal Sinatra Worker.
# Copy and replace YOUR_* placeholders.

name = "YOUR_WORKER_NAME"
main = "src/worker.mjs"
compatibility_date = "2024-01-01"

# Point to the Opal bundle emitted by cloudflare_workers:opal (or npm script).
# homura wires Ruby via `globalThis.__HOMURA_RACK_DISPATCH__` — follow
# gems/homura-runtime/runtime/worker.mjs as a template.

[vars]
# EXAMPLE = "1"

# [[d1_databases]]
# binding = "DB"
# database_name = "YOUR_DB"
# database_id = "YOUR_ID"
