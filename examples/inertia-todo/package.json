{
  "name": "inertia-todo",
  "private": true,
  "type": "module",
  "scripts": {
    "client:install": "cd client && npm install",
    "client:build": "cd client && npm run build",
    "client:dev": "cd client && npm run dev",
    "build": "npm run client:build && bundle exec rake build",
    "dev": "bundle exec rake dev",
    "deploy": "npm run client:build && bundle exec rake deploy"
  },
  "devDependencies": {
    "wrangler": "^3.99.0"
  },
  "engines": {
    "node": ">=20"
  }
}
