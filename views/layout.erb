<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title><%= @title || 'homurabi' %></title>
    <style>
      body   { font: 16px/1.5 -apple-system, BlinkMacSystemFont, sans-serif; color: #222; max-width: 42em; margin: 3em auto; padding: 0 1em; }
      h1     { color: #0073bb; }
      h2     { color: #555; margin-top: 1.5em; }
      code   { background: #f4f4f4; padding: 0 .3em; border-radius: 3px; }
      pre    { background: #f4f4f4; padding: 1em; border-radius: 4px; overflow: auto; }
      ul     { line-height: 2; }
      a      { color: #e4572e; }
      footer { margin-top: 3em; color: #888; font-size: .9em; }
      nav a  { margin-right: 1em; }
      .badge { display: inline-block; padding: 0.1em 0.5em; border-radius: 10px; background: #0073bb; color: #fff; font-size: .8em; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/hello/world">/hello/world</a>
      <a href="/about">About</a>
      <a href="/d1/users">D1 users</a>
    </nav>
    <hr>
    <%= @content %>
    <footer>
      homurabi — real Sinatra on Cloudflare Workers via Opal &middot;
      <a href="https://github.com/kazuph/homurabi">source</a>
    </footer>
  </body>
</html>
