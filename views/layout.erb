<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title><%= @title || 'homurabi' %></title>
    <link rel="icon" type="image/png" href="/images/favicon.png" sizes="32x32">
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
    <link rel="stylesheet" href="/style.css">
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/d1/users">D1</a>
      <a href="/demo/sequel">Sequel</a>
      <a href="/posts">Posts</a>
      <a href="/demo/http">HTTP</a>
      <a href="/chat" class="nav-chat">Chat ⚡</a>
      <% if @current_user %>
        <span style="margin-left:auto;color:#666;font-size:0.9em;">
          <%= Rack::Utils.escape_html(@current_user.to_s) %> &middot;
          <a href="/logout">Logout</a>
        </span>
      <% else %>
        <span style="margin-left:auto;font-size:0.9em;">
          <a href="/login">Login</a>
        </span>
      <% end %>
    </nav>
    <hr>
    <%= @content %>
    <footer>
      homurabi — real Sinatra on Cloudflare Workers via Opal &middot;
      <a href="https://github.com/kazuph/homurabi">source</a>
    </footer>
  </body>
</html>
