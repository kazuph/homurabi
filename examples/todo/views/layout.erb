<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>homura todo</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif; max-width: 640px; margin: 2rem auto; padding: 0 1rem; color: #222; }
    h1 { font-size: 1.4rem; }
    form.new-todo { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
    form.new-todo input[type=text] { flex: 1; padding: 0.4rem 0.6rem; border: 1px solid #bbb; border-radius: 4px; }
    form.new-todo button { padding: 0.4rem 0.8rem; cursor: pointer; }
    ul.todos { list-style: none; padding: 0; }
    ul.todos li { display: flex; align-items: center; gap: 0.5rem; padding: 0.4rem 0; border-bottom: 1px solid #eee; }
    ul.todos li.done .title { color: #888; text-decoration: line-through; }
    ul.todos .title { flex: 1; }
    ul.todos form { display: inline; margin: 0; }
    ul.todos button { padding: 0.2rem 0.5rem; cursor: pointer; }
    .meta { color: #888; font-size: 0.85rem; margin-top: 1.5rem; }
  </style>
</head>
<body>
  <%= yield %>
  <p class="meta">D1 (Cloudflare D1) backed storage.</p>
</body>
</html>
