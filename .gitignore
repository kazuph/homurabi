# Ruby / Bundler — match at any depth so the same rules apply at the
# repo root (gem dev workspace) and under site/ (canonical app).
.bundle/
vendor/bundle/
Gemfile.lock.local
.ruby-version.local

# Node / wrangler
node_modules/
.wrangler/
.dev.vars

# Opal build outputs (keep generated Workers entry tracked for wrangler main)
build/**
!build/worker.entrypoint.mjs
dist/
*.opal.js
*.opal.mjs

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Local secrets
.env
.env.local

# mise local config (per-machine)
.mise.local.toml

# Claude Code per-machine permission overrides (the project-wide
# `.claude/settings.json` is tracked; `.claude/settings.local.json`
# is the per-developer allow-list and should never be committed).
.claude/settings.local.json

# Local task artifacts (report/evidence, do not version)
.artifacts/
