#!/usr/bin/env ruby
# frozen_string_literal: true
#
# homura ERB precompiler.
#
# Opal-on-Workers can't run ERB the normal way: ERB compiles its
# templates to Ruby source and runs them via `binding.eval`, which
# lands on `new Function($code)`, which Cloudflare Workers bans with
# "Code generation from strings disallowed for this context".
#
# The workaround is to compile each ERB template to a *plain Ruby
# method* ahead of time (in CRuby, at build time), then feed that
# generated Ruby source into Opal alongside everything else. The
# runtime cost is a single Proc lookup plus a couple of string
# concatenations per tag; no eval, no new Function, no surprises.
#
# Usage:
#   bin/compile-erb --input views --output build/homura_templates.rb --namespace HomuraTemplates
# or (legacy):
#   bin/compile-erb views/foo.erb   # writes compiled templates + Sinatra hook to stdout
#
# The output registers each template with `HomuraTemplates` and
# monkey-patches `Sinatra::Templates#erb` to dispatch there.

require 'fileutils'
require 'optparse'

HELP = <<~USAGE
  Usage:
    bin/compile-erb [--input DIR] [--output FILE] [--namespace ModuleName]
                    [--stdout] [--] [template.erb ...]

  Defaults (Phase 15-A homura):
    --input views --output build/homura_templates.rb --namespace HomuraTemplates

  With positional .erb paths and no --output: print combined Ruby to stdout (legacy).
USAGE

# Very small ERB dialect tokenizer. ERB is simple enough to parse by
# hand and we specifically DO NOT want to pull in stdlib ERB — its
# generated source uses `String#<<` mutation, which Opal's immutable
# Strings reject at runtime.
module HomuraERB
  module_function

  def supported_yield_fragment?(fragment)
    stripped = fragment.strip
    stripped.match?(/\Ayield(?:\(\s*\))?\z/)
  end

  def yield_with_args_fragment?(fragment)
    fragment.strip.match?(/\Ayield\s*\(.+\)\z/)
  end

  def normalize_fragment(fragment)
    return '__homura_template_yield__' if supported_yield_fragment?(fragment)
    rewrite_class_variables(fragment)
  end

  # Opal compiles class-variable reads/writes (`@@foo`) into accessors
  # bound to the lexically enclosing class, but precompiled ERB bodies
  # are evaluated through `instance_exec` on a Sinatra instance whose
  # `$$cvars` slot is undefined at that runtime path. The result is a
  # `TypeError: Cannot read properties of undefined (reading '$$cvars')`
  # the moment a template touches `<%= @@todos %>` directly — exactly
  # the natural Sinatra style we want users to be able to keep writing.
  #
  # Rewrite both reads (`@@foo`) and writes (`@@foo = expr`) into
  # explicit `class_variable_get` / `class_variable_set` calls on the
  # instance's class so the same source compiles cleanly under Opal
  # without requiring `@foo = @@foo` shims at the route layer.
  #
  # The rewrite is a deliberately small regex pass: ERB fragments are
  # short, and class-variable tokens inside Ruby string literals or
  # comments are vanishingly rare in real templates. Anything more
  # ambitious would need a Ruby parser, which is overkill for the
  # `@@ivar` shape we actually have to handle here.
  CVAR_OP_ASSIGN_RE = /(?<![@\w])@@([A-Za-z_]\w*)\s*(\|\||&&|\+|-|\*|\/|%|\*\*|<<|>>|\||&|\^)=\s*([^;\n]+)/.freeze
  CVAR_ASSIGN_RE = /(?<![@\w])@@([A-Za-z_]\w*)\s*=(?!=)\s*([^;\n]+)/.freeze
  # Read pattern excludes `@@name` that appears on the left-hand side
  # of an assignment (`@@name =`, `@@name +=`, `@@name ||=`, etc.) so
  # the assignment passes still see the raw token to rewrite. The
  # `=(?!=)` guard keeps `==` (comparison) treated as a read.
  CVAR_READ_RE = %r{
    (?<![@\w])@@([A-Za-z_]\w*)\b
    (?!
      \s*
      (?:\|\||&&|\+|-|\*|/|%|\*\*|<<|>>|\||&|\^)?
      =(?!=)
    )
  }x.freeze

  CVAR_PLACEHOLDER_PREFIX = "\x01HOMURA_CVAR\x01".freeze
  CVAR_PLACEHOLDER_SUFFIX = "\x01".freeze

  def rewrite_class_variables(fragment)
    return fragment unless fragment.include?('@@')

    placeholders = []
    record = lambda do |replacement|
      placeholders << replacement
      "#{CVAR_PLACEHOLDER_PREFIX}#{placeholders.length - 1}#{CVAR_PLACEHOLDER_SUFFIX}"
    end

    # Reads first: rewrite every `@@name` that is *not* the target of
    # an assignment, including occurrences on the right-hand side of
    # an assignment. Each match collapses into a sentinel so the
    # later assignment passes see the original `@@name = ...` shape
    # (without their RHS reads being clobbered) and so the final
    # output never re-enters this same rewrite loop.
    work = fragment.gsub(CVAR_READ_RE) do
      name = Regexp.last_match(1)
      record.call("self.class.class_variable_get(:@@#{name})")
    end

    work = work.gsub(CVAR_OP_ASSIGN_RE) do
      name = Regexp.last_match(1)
      op = Regexp.last_match(2)
      value = Regexp.last_match(3)
      replacement =
        case op
        when '||'
          "self.class.class_variable_set(:@@#{name}, (self.class.class_variable_defined?(:@@#{name}) ? self.class.class_variable_get(:@@#{name}) : nil) || (#{value}))"
        when '&&'
          "self.class.class_variable_set(:@@#{name}, (self.class.class_variable_defined?(:@@#{name}) ? self.class.class_variable_get(:@@#{name}) : nil) && (#{value}))"
        else
          "self.class.class_variable_set(:@@#{name}, self.class.class_variable_get(:@@#{name}) #{op} (#{value}))"
        end
      record.call(replacement)
    end

    work = work.gsub(CVAR_ASSIGN_RE) do
      name = Regexp.last_match(1)
      value = Regexp.last_match(2)
      record.call("self.class.class_variable_set(:@@#{name}, (#{value}))")
    end

    placeholder_re = /#{Regexp.escape(CVAR_PLACEHOLDER_PREFIX)}(\d+)#{Regexp.escape(CVAR_PLACEHOLDER_SUFFIX)}/
    loop do
      replaced = work.gsub(placeholder_re) { placeholders[Regexp.last_match(1).to_i] }
      break if replaced == work
      work = replaced
    end
    work
  end

  def validate_code_fragment!(fragment)
    stripped = fragment.strip
    return unless supported_yield_fragment?(stripped) || yield_with_args_fragment?(stripped)

    raise <<~MSG.strip
      Unsupported ERB yield form `<% #{stripped} %>`.
      Use `<%= yield %>` or `<%== yield %>` in layout templates.
    MSG
  end

  def validate_expression_fragment!(fragment)
    stripped = fragment.strip
    return unless yield_with_args_fragment?(stripped)

    raise <<~MSG.strip
      Unsupported ERB yield form `<%= #{stripped} %>`.
      `yield(arg)` is not supported; use `<%= yield %>` or `<%== yield %>`, or pass data via ivars/locals instead.
    MSG
  end

  # Compile an ERB source string to a Ruby method body that assembles
  # an HTML string in a local variable `_out`. The body references
  # `@ivars` and method calls directly, so it must be run via
  # `instance_exec` on the Sinatra instance the route was dispatched
  # on. That gives `<%= @name %>` the usual Sinatra semantics. Layout
  # templates can also write `<%= yield %>` — we rewrite that specific
  # form to an instance helper because Ruby's `yield` keyword is not
  # valid inside the Proc body we generate here.
  def compile(source)
    ruby = +"_out = ''\n"
    cursor = 0
    while cursor < source.length
      open_idx = source.index('<%', cursor)
      if open_idx.nil?
        static = source[cursor..]
        ruby << "_out = _out + #{static.inspect}\n" unless static.empty?
        break
      end

      # Static text before the next `<%`
      if open_idx > cursor
        static = source[cursor...open_idx]
        ruby << "_out = _out + #{static.inspect}\n"
      end

      close_idx = source.index('%>', open_idx + 2)
      raise "Unmatched `<%` in ERB source (starting at #{open_idx})" if close_idx.nil?

      inner = source[(open_idx + 2)...close_idx]

      if inner.start_with?('#')
        # `<%# comment %>` — drop
      elsif inner.start_with?('==')
        # `<%== expression %>` — identical to `<%= %>` in this minimal
        # dialect (no HTML escaping yet; the author is responsible).
        expr = inner[2..].strip
        validate_expression_fragment!(expr)
        expr = normalize_fragment(expr)
        ruby << "_out = _out + ((#{expr})).to_s\n"
      elsif inner.start_with?('=')
        # `<%= expression %>`
        expr = inner[1..].strip
        validate_expression_fragment!(expr)
        expr = normalize_fragment(expr)
        ruby << "_out = _out + ((#{expr})).to_s\n"
      else
        # `<% code %>` — Ruby statement(s), emitted verbatim
        code = inner.strip
        validate_code_fragment!(code)
        ruby << normalize_fragment(code) << "\n"
      end

      cursor = close_idx + 2
    end
    ruby << "_out\n"
    ruby
  end

  # Wrap the compiled body in a `#{namespace}.register` call.
  # `template_name` may be a Symbol whose name contains a `/`
  # (e.g. `:"posts/index"`); use `inspect` so the literal serialises
  # as `:"posts/index"` and is parseable by Opal.
  def wrap(template_name, compiled_body, namespace)
    indented = compiled_body.each_line.map { |l| "    #{l}" }.join
    <<~RUBY
      #{namespace}.register(#{template_name.inspect}) do |locals = {}|
      #{indented.chomp}
      end
    RUBY
  end
end

# ---------------------------------------------------------------------------
# Driver
# ---------------------------------------------------------------------------

def default_inputs_for(dir)
  # Recursive so `views/posts/index.erb` becomes `:'posts/index'`,
  # matching upstream Sinatra's subdirectory convention.
  Dir.glob(File.join(dir, '**', '*.erb')).sort
end

def template_name_for(path, root)
  rel = path.dup
  if root
    root_with_sep = root.end_with?('/') ? root : "#{root}/"
    rel = rel[root_with_sep.length..] if rel.start_with?(root_with_sep)
  end
  rel = File.basename(rel) unless rel.include?('/')
  rel.delete_suffix('.erb').to_sym
end

def emit_header(io, namespace)
  io.puts <<~RUBY
    # frozen_string_literal: true
    #
    # Auto-generated by bin/compile-erb — DO NOT EDIT BY HAND.
    #
    # Run `bin/compile-erb` after modifying anything under views/ to
    # regenerate. The Opal build command picks this file up via
    # `-I build -r homura_templates` (or your chosen `--output` basename).
    #
    # Each registered template is a Proc that returns an HTML String.
    # The Proc is `instance_exec`'d on the current Sinatra instance so
    # `@ivars`, `params`, `request`, and any Sinatra helper remain
    # accessible exactly as they would in a stock Sinatra route.
    #
    # Rendering is wired to `Sinatra::Templates#erb` further down so
    # `erb :index` in user code dispatches here transparently. No
    # runtime eval, no `new Function`, no Workers sandbox complaints.

    module #{namespace}
      @templates = {}

      class << self
        def register(name, &body)
          @templates[name.to_sym] = body
        end

        def render(name, instance, locals = {}, &block)
          body = @templates[name.to_sym]
          raise "#{namespace}: no template registered for \#{name.inspect}" unless body
          previous_block = instance.instance_variable_get(:@__homura_template_block__)
          begin
            instance.instance_variable_set(:@__homura_template_block__, block)
            instance.instance_exec(locals, &body)
          ensure
            instance.instance_variable_set(:@__homura_template_block__, previous_block)
          end
        end

        def registered?(name)
          @templates.key?(name.to_sym)
        end

        def names
          @templates.keys
        end
      end
    end
  RUBY
end

def emit_templates(io, inputs, namespace, root)
  inputs.each do |path|
    name = template_name_for(path, root)
    source = File.read(path)
    compiled = HomuraERB.compile(source)
    io.puts
    io.puts "# ---- #{path} -> :#{name.inspect} --------------------------------------"
    io.puts HomuraERB.wrap(name, compiled, namespace)
  end
end

def emit_sinatra_patch(io, namespace)
  io.puts <<~RUBY

    # ---------------------------------------------------------------------
    # Sinatra hook: `erb :name` dispatches to #{namespace}.render.
    # ---------------------------------------------------------------------
    #
    # This file is loaded by Opal via `-r homura_templates` before
    # `app/hello.rb`, so Sinatra is not yet loaded at require time.
    # Pull it in explicitly and reopen `Sinatra::Templates` to install
    # our ERB dispatcher. User code's own `require 'sinatra/base'`
    # later becomes a no-op (already cached).
    require 'sinatra/base'

    module ::Sinatra
      module Templates
        def __homura_template_yield__
          block = @__homura_template_block__
          raise LocalJumpError, 'no block given' unless block

          block.call
        end

        def __homura_default_template_block_for__(template)
          case template.to_sym
          when :layout
            proc { @content } if defined?(@content)
          when :layout_docs
            proc { @docs_inner } if defined?(@docs_inner)
          end
        end

        # homura patch: dispatch to precompiled templates when we
        # have one. Unknown symbols raise a clear message instead of
        # wandering into upstream Tilt, which would blow up on
        # Workers with "Code generation from strings disallowed".
        #
        # Sinatra's idiom `erb :foo, locals: { x: 1 }` passes locals via
        # `options[:locals]` rather than the third positional argument;
        # merge them so both forms work.
        def erb(template, options = {}, locals = {}, &block)
          template = template.to_sym if template.is_a?(::String)
          if template.is_a?(::Symbol) && ::#{namespace}.registered?(template)
            locals = (options[:locals] || {}).merge(locals || {})
            block ||= __homura_default_template_block_for__(template)
            output = ::#{namespace}.render(template, self, locals, &block)

            layout = options[:layout]
            layout = false if layout.nil? && options.include?(:layout)
            if layout.nil? && template.to_sym != :layout && ::#{namespace}.registered?(:layout)
              layout = :layout
            end
            if layout
              layout = :layout if layout == true
              layout = layout.to_sym
              raise "homura: layout \#{layout.inspect} not precompiled; run bin/compile-erb" unless ::#{namespace}.registered?(layout)

              return ::#{namespace}.render(layout, self, locals) { output }
            end

            output
          else
            raise "homura: erb \#{template.inspect} not precompiled; run bin/compile-erb"
          end
        end
      end
    end
  RUBY
end

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

if ARGV.include?('-h') || ARGV.include?('--help')
  puts HELP
  exit 0
end

options = {
  input_dir: 'views',
  output: 'build/homura_templates.rb',
  namespace: 'HomuraTemplates',
  stdout: false
}

parser = OptionParser.new do |op|
  op.banner = 'Usage: bin/compile-erb [options] [--] [files...]'
  op.on('--input DIR', 'Directory containing *.erb templates') { |d| options[:input_dir] = d }
  op.on('--output PATH', 'Write generated Ruby to PATH') { |p| options[:output] = p }
  op.on('--namespace NAME', 'Ruby module name for the registry') { |n| options[:namespace] = n }
  op.on('--stdout', 'Write generated Ruby to stdout') { options[:stdout] = true }
end
parser.parse!

positional = ARGV.dup
namespace = options[:namespace]

inputs =
  if positional.any?
    positional.flat_map { |a| File.directory?(a) ? Dir.glob(File.join(a, '**', '*.erb')).sort : [a] }
  else
    default_inputs_for(options[:input_dir])
  end

template_root = positional.find { |a| File.directory?(a) } || options[:input_dir]

if inputs.empty?
  warn "bin/compile-erb: no .erb files found (under #{options[:input_dir]}/ or from args)"
  exit 1
end

write_file = !options[:stdout] && (positional.empty? || options[:output])
out_path = options[:output]

if write_file
  FileUtils.mkdir_p(File.dirname(out_path))
  File.open(out_path, 'w') do |io|
    emit_header(io, namespace)
    emit_templates(io, inputs, namespace, template_root)
    emit_sinatra_patch(io, namespace)
  end
  warn "compile-erb: wrote #{out_path} (#{inputs.size} templates)"
else
  emit_header($stdout, namespace)
  emit_templates($stdout, inputs, namespace, template_root)
  emit_sinatra_patch($stdout, namespace)
end
