#!/usr/bin/env ruby
# frozen_string_literal: true
#
# homura db:migrate:* — under CRuby, compile Sequel migration DSL
# files into wrangler-ready `.sql`, and optionally shell out to wrangler
# to apply them.
#
# Usage:
#   homura db:migrate:compile <migrations_dir> [--out DIR]
#   homura db:migrate:apply [--remote] [--database NAME]
#
# Environment:
#   WRANGLER_BIN             wrangler executable (default: wrangler)
#   CLOUDFLARE_D1_DATABASE   default D1 database name for `apply`
#   WRANGLER_D1_DATABASE     alias for CLOUDFLARE_D1_DATABASE

require 'fileutils'
require 'optparse'
require 'logger'

def wrangler_executable
  bin = ENV['WRANGLER_BIN'].to_s.strip
  bin.empty? ? 'wrangler' : bin
end

def usage!(msg = nil)
  warn msg if msg
  warn <<~USAGE
    Usage:
      homura db:migrate:compile <migrations_dir> [--out DIR]
      homura db:migrate:apply [--remote] [--database NAME]

    Environment:
      WRANGLER_BIN              wrangler executable (default: wrangler)
      CLOUDFLARE_D1_DATABASE    default database name for apply
  USAGE
  exit 1
end

def require_sequel_sqlite!
  begin
    require 'sequel'
    Sequel.extension :migration
  rescue LoadError
    warn 'ERROR: `sequel` gem is required.'
    exit 1
  end
  begin
    require 'sqlite3'
  rescue LoadError
    warn 'ERROR: `sqlite3` gem is required.'
    exit 1
  end
end

def run_compile
  migrations_dir = ARGV.shift
  unless migrations_dir && File.directory?(migrations_dir)
    warn "ERROR: migrations_dir '#{migrations_dir}' not found"
    exit 1
  end

  out_dir = migrations_dir
  OptionParser.new do |o|
    o.on('--out DIR', 'Output directory for compiled SQL files') { |v| out_dir = v }
  end.parse!(ARGV)
  FileUtils.mkdir_p(out_dir)

  require_sequel_sqlite!

  migration_files = Dir.glob(File.join(migrations_dir, '*.rb')).sort
  if migration_files.empty?
    warn "ERROR: no .rb migration files found in #{migrations_dir}"
    exit 1
  end

  migration_files.each_with_index do |rb, idx|
    base = File.basename(rb, '.rb')
    number = (base =~ /\A(\d+)_/) ? Regexp.last_match(1) : format('%04d', idx + 1)

    captured = []
    db = Sequel.sqlite(logger: Logger.new(nil))
    db.sql_log_level = :info

    sqls = captured
    db.define_singleton_method(:log_connection_yield) do |sql, _conn, *, &blk|
      sqls << sql unless sql.strip.start_with?('PRAGMA')
      blk.call
    end

    migration_files[0...idx].each do |prev|
      migration = eval(File.read(prev), binding, prev)
      migration.apply(db, :up)
    end

    sqls.clear

    migration = eval(File.read(rb), binding, rb)
    migration.apply(db, :up)

    out_path = File.join(out_dir, "#{number}_#{base.sub(/\A\d+_/, '')}.sql")
    File.write(out_path, captured.map { |s| "#{s};" }.join("\n") + "\n")
    puts "→ #{out_path} (#{captured.size} statement#{'s' if captured.size != 1})"
  end

  puts
  puts "✓ Compiled #{migration_files.size} migration(s) to #{out_dir}/"
  dbname = ENV['CLOUDFLARE_D1_DATABASE'] || ENV['WRANGLER_D1_DATABASE'] || '<database>'
  puts "  Apply with: homura db:migrate:apply --database #{dbname}"
  puts "            or: homura db:migrate:apply --remote --database #{dbname}"
end

def run_apply
  remote = false
  database = nil
  OptionParser.new do |o|
    o.on('--remote', 'Apply migrations to remote D1') { remote = true }
    o.on('--database NAME', 'D1 database name (as in wrangler.toml)') { |v| database = v }
  end.parse!(ARGV)

  database ||= ENV['CLOUDFLARE_D1_DATABASE'] || ENV['WRANGLER_D1_DATABASE']
  unless database
    warn 'ERROR: database name required (--database or CLOUDFLARE_D1_DATABASE)'
    exit 1
  end

  wr = wrangler_executable
  cmd = [wr, 'd1', 'migrations', 'apply', database]
  cmd << (remote ? '--remote' : '--local')

  warn "+ #{cmd.join(' ')}"
  exec(*cmd)
end

cmd = ARGV.shift
case cmd
when 'compile'
  run_compile
when 'apply'
  run_apply
else
  usage!(cmd ? "Unknown command: #{cmd}" : nil)
end
