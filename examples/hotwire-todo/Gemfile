# frozen_string_literal: true
source 'https://rubygems.org'

ruby '>= 3.4.0'

gem 'rake'
gem 'opal-homura', '= 1.8.3.rc1.5', require: 'opal'
gem 'homura-runtime', '= 0.3.6'
gem 'sinatra-homura', '= 0.3.2'

# D1 / Sequel migrations (compile-time only). The Worker itself talks to D1
# directly through `db` (sqlite3-ruby compatible API), but
# `bundle exec rake db:migrate:compile` needs Sequel + sqlite3 locally to
# compile Sequel migration DSL into wrangler-compatible SQL.
gem 'sequel-d1', '= 0.3.1'
gem 'sequel', '~> 5.0'
gem 'sqlite3', '>= 2.0'
