<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<title>Inertia × homura Todo</title>
<style>
  body { font-family: -apple-system, "Helvetica Neue", sans-serif; max-width: 640px; margin: 2rem auto; padding: 0 1rem; }
  .page h1 { font-size: 1.4rem; }
  form { display: flex; gap: .5rem; margin-bottom: 1rem; }
  form input[type=text] { flex: 1; padding: .4rem; }
  ul { list-style: none; padding: 0; }
  li { display: flex; align-items: center; gap: .5rem; padding: .3rem 0; border-bottom: 1px solid #eee; }
  li span { flex: 1; }
  button { cursor: pointer; }
</style>
<script type="importmap">
{
  "imports": {
    "vue": "https://esm.sh/vue@3.5.13/dist/vue.esm-browser.prod.js",
    "@inertiajs/vue3": "https://esm.sh/@inertiajs/vue3@1.3.0?deps=vue@3.5.13"
  }
}
</script>
</head>
<body>
<div id="app" data-page="<%= Rack::Utils.escape_html(@page_json) %>"></div>
<script type="module" src="/assets/inertia-app.js"></script>
</body>
</html>
