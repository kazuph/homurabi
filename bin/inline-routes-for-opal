#!/usr/bin/env ruby
# frozen_string_literal: true
# Reads app/routes/canonical_all.rb and emits build/routes_app_class_eval.rb
# wrapped in App.class_eval so route DSL runs in the App class (Opal + Workers).

ROOT   = File.expand_path('..', __dir__)
SOURCE = File.join(ROOT, 'app/routes/canonical_all.rb')
OUT    = File.join(ROOT, 'build/routes_app_class_eval.rb')

lines = File.readlines(SOURCE)
await_line = lines.find { |l| l.start_with?('# await:') }&.strip || File.readlines(File.join(ROOT, 'app/hello.rb')).find { |l| l.start_with?('# await:') }&.strip
abort "#{SOURCE}: missing # await: (Phase 12.5); routes would not auto-await in Opal" unless await_line

body_start = lines.index { |l| l =~ /^  (get|post|put|delete|patch) / }
abort "#{SOURCE}: no indented route line found" unless body_start

inner = lines[body_start..].join

# `# await:` MUST be the first line of this compilation unit (same as hello.rb / app.rb)
# or db.execute / Sequel / JWT in route bodies stay as Promises and Workers throw 1101.
File.write(OUT, <<~RUBY)
  #{await_line}
  # frozen_string_literal: true
  # GENERATED by bin/inline-routes-for-opal — do not edit by hand.
  App.class_eval do
  #{inner}end
RUBY

puts "Wrote #{OUT} (#{File.size(OUT)} bytes)"
