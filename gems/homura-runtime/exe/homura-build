#!/usr/bin/env ruby
# frozen_string_literal: true

# homura build: ERB precompile → assets embed → Opal bundle → patch-opal-evals → worker.entrypoint.mjs
# Use --standalone for generated consumer apps (no homura inline routes).

require 'fileutils'
require 'open3'
require 'optparse'
require 'pathname'
require_relative '../lib/cloudflare_workers/build_support'

module CloudflareWorkersBuild
  class << self
    def gem_root
      CloudflareWorkers::BuildSupport.runtime_root(current_file: __FILE__)
    end

    def runtime_dir
      gem_root.join('runtime')
    end

    def exe_path(name)
      gem_root.join('exe', name)
    end

    def gem_lib(*names)
      CloudflareWorkers::BuildSupport.gem_lib(*names)
    end

    def gem_vendor(*names)
      CloudflareWorkers::BuildSupport.gem_vendor(*names)
    end
  end
end

options = {
  root: Dir.pwd,
  standalone: false,
  opal_input: ENV['HOMURA_OPAL_INPUT'],
  opal_output: ENV['HOMURA_OPAL_OUTPUT'] || 'build/hello.no-exit.mjs',
  patch_input: ENV['HOMURA_OPAL_PATCH_INPUT'],
  setup_import: nil,
  bundle_import: nil,
  worker_module_import: nil,
  entrypoint_out: nil,
  with_db: false,
  templates_namespace: nil,
  assets_namespace: nil
}

OptionParser.new do |o|
  o.banner = 'usage: homura build [options]'
  o.on('--root PATH', 'Project root (default: cwd)') { |p| options[:root] = p }
  o.on('--standalone', 'Consumer app (skip inline-routes; use Gemfile-resolved load paths)') do
    options[:standalone] = true
  end
  o.on('--with-db', 'Include sequel-d1 on Opal load path (standalone)') do
    options[:with_db] = true
  end
  o.on('--input PATH', 'Opal entry .rb') { |p| options[:opal_input] = p }
  o.on('--output PATH', 'Opal bundle .mjs') { |p| options[:opal_output] = p }
  o.on('--patch-input PATH', 'Override patch target (default: same as --output)') { |p| options[:patch_input] = p }
  o.on('--setup-import PATH', 'setup-node-crypto import in entrypoint') { |p| options[:setup_import] = p }
  o.on('--bundle-import PATH', 'Opal bundle import in entrypoint') { |p| options[:bundle_import] = p }
  o.on('--worker-module-import PATH', 'worker_module.mjs import in entrypoint') { |p| options[:worker_module_import] = p }
  o.on('--entrypoint-out PATH', 'Where to write worker.entrypoint.mjs') { |p| options[:entrypoint_out] = p }
  o.on('--templates-namespace NAME', 'Standalone templates module name (default: project-derived)') { |n| options[:templates_namespace] = n }
  o.on('--assets-namespace NAME', 'Standalone assets module name (default: project-derived)') { |n| options[:assets_namespace] = n }
end.parse!

options[:standalone] = true if options[:with_db]

root = Pathname(options[:root]).expand_path
options[:templates_namespace] ||= CloudflareWorkers::BuildSupport.standalone_namespace(root, 'Templates') if options[:standalone]
options[:assets_namespace] ||= CloudflareWorkers::BuildSupport.standalone_namespace(root, 'Assets') if options[:standalone]

if options[:standalone]
  Dir.chdir(root) { require 'bundler/setup' }
  # Both .mjs glue files and the entrypoint live under `build/` from
  # 0.2.23 on. write_entrypoint! resolves these as project-root
  # relative paths and computes the entrypoint-relative import spec.
  options[:setup_import] ||= 'build/cf-runtime/setup-node-crypto.mjs'
  options[:bundle_import] ||= options[:opal_output]
  options[:worker_module_import] ||= 'build/cf-runtime/worker_module.mjs'
  options[:entrypoint_out] ||= 'build/worker.entrypoint.mjs'
else
  options[:setup_import] ||= 'gems/homura-runtime/runtime/setup-node-crypto.mjs'
  options[:bundle_import] ||= options[:opal_output]
  options[:worker_module_import] ||= 'gems/homura-runtime/runtime/worker_module.mjs'
  options[:entrypoint_out] ||= 'build/worker.entrypoint.mjs'
end

patch_target = options[:patch_input] || options[:opal_output]

def run!(argv, chdir:)
  Dir.chdir(chdir) do
    system(*argv) || abort("homura build: failed: #{argv.join(' ')}")
  end
end

def run_opal_homura!(root, opal_input, opal_output)
  argv = [
    'bundle', 'exec', 'opal',
    '-c', '-E', '--esm', '--no-source-map',
    '-I', '.',
    '-I', 'build/auto_await/app', '-I', 'build/auto_await', '-I', 'app',
    '-I', 'gems/homura-runtime/lib',
    '-I', 'gems/sinatra-homura/lib',
    '-I', 'gems/sequel-d1/lib',
    '-I', 'lib', '-I', 'vendor', '-I', 'build',
    '-r', 'opal_patches', '-r', 'cloudflare_workers',
    '-r', 'homura_templates', '-r', 'homura_assets',
    '-o', opal_output,
    opal_input
  ]
  stderr_log = root.join('build/opal.stderr.log')
  FileUtils.mkdir_p(root.join('build'))
  env = { 'OPAL_PREFORK_DISABLE' => '1' }
  out_err, status = Open3.capture2e(env, *argv, chdir: root.to_s)
  File.write(stderr_log, out_err)
  abort("homura build: opal failed (see #{stderr_log})") unless status.success?
end

def homura_vendor_from_gemfile(project_root)
  CloudflareWorkers::BuildSupport.vendor_from_gemfile(project_root)
end

def run_opal_standalone!(root, opal_input, opal_output, with_db:)
  load_paths = CloudflareWorkers::BuildSupport.standalone_load_paths(root, with_db: with_db)

  argv = ['bundle', 'exec', 'opal', '-c', '-E', '--esm', '--no-source-map']
  load_paths.each { |p| argv.push('-I', p) }
  argv += %w[-r opal_patches -r cloudflare_workers -r app_templates -r app_assets -o] + [opal_output, opal_input]

  stderr_log = root.join('build/opal.stderr.log')
  FileUtils.mkdir_p(root.join('build'))
  env = { 'OPAL_PREFORK_DISABLE' => '1' }
  out_err, status = Open3.capture2e(env, *argv, chdir: root.to_s)
  File.write(stderr_log, out_err)
  abort("homura build: opal failed (see #{stderr_log})") unless status.success?
end

def write_entrypoint!(root, out_path, setup:, bundle:, worker_mod:)
  out_file = root.join(out_path)
  out_dir = out_file.dirname
  body = <<~JS
    // GENERATED by homura build — do not edit by hand.
    import "#{relative_import_spec(out_dir, root.join(setup))}";
    import "#{relative_import_spec(out_dir, root.join(bundle))}";
    export { default, HomuraCounterDO } from "#{relative_import_spec(out_dir, root.join(worker_mod))}";
  JS
  File.write(out_file, body)
end

def relative_import_spec(from_dir, target_path)
  rel = Pathname(target_path).relative_path_from(Pathname(from_dir)).to_s
  rel.start_with?('.', '/') ? rel : "./#{rel}"
end

def resolve_opal_input(root, explicit_input)
  return explicit_input if explicit_input

  candidates = ['config.ru', 'app/hello.rb', 'app/app.rb']
  found = candidates.find { |path| root.join(path).file? }
  return found if found

  abort("homura build: no default entrypoint found (looked for #{candidates.join(', ')})")
end

def prepare_opal_input(root, input_path)
  rel = Pathname(input_path)
  rel = root.join(rel).relative_path_from(root) if rel.absolute?
  return [rel.to_s, nil] unless rel.extname == '.ru'

  tmp_dir = root.join('build', 'auto_await')
  tmp_dir = root unless tmp_dir.directory?
  tmp = tmp_dir.join(".homura-build-#{rel.basename}.rb")
  FileUtils.mkdir_p(tmp.dirname)
  File.write(tmp, root.join(rel).read)
  [tmp.relative_path_from(root).to_s, tmp]
end

unless options[:standalone]
  run!(['ruby', 'bin/inline-routes-for-opal'], chdir: root)
  run!(
    [
      'ruby', CloudflareWorkersBuild.exe_path('auto-await').to_s,
      '--input', 'app',
      '--output', 'build/auto_await/app'
    ],
    chdir: root
  )
  run!(
    [
      'ruby', CloudflareWorkersBuild.exe_path('auto-await').to_s,
      '--input', 'build/routes_app_class_eval.rb',
      '--output', 'build/auto_await/routes_app_class_eval.rb'
    ],
    chdir: root
  )
  run!(
    [
      'ruby', CloudflareWorkersBuild.exe_path('compile-erb').to_s,
      '--input', 'views',
      '--output', 'build/homura_templates.rb',
      '--namespace', 'HomuraTemplates'
    ],
    chdir: root
  )
  run!(
    [
      'ruby', CloudflareWorkersBuild.exe_path('compile-assets').to_s,
      '--input', 'public',
      '--output', 'build/homura_assets.rb',
      '--namespace', 'HomuraAssets'
    ],
    chdir: root
  )

  opal_in = Pathname(resolve_opal_input(root, options[:opal_input]))
  opal_out = Pathname(options[:opal_output])
  opal_in = root.join(opal_in) unless opal_in.absolute?
  opal_out = root.join(opal_out) unless opal_out.absolute?
  prepared_in, temp_input = prepare_opal_input(root, opal_in)
  begin
    run_opal_homura!(root, prepared_in, opal_out.relative_path_from(root).to_s)
  ensure
    FileUtils.rm_f(temp_input) if temp_input
  end
else
  CloudflareWorkers::BuildSupport.ensure_standalone_runtime(root, current_file: __FILE__)
  run!(
    [
      'ruby', CloudflareWorkersBuild.exe_path('compile-erb').to_s,
      '--input', 'views',
      '--output', 'build/app_templates.rb',
      '--namespace', options[:templates_namespace]
    ],
    chdir: root
  )
  run!(
    [
      'ruby', CloudflareWorkersBuild.exe_path('compile-assets').to_s,
      '--input', 'public',
      '--output', 'build/app_assets.rb',
      '--namespace', options[:assets_namespace]
    ],
    chdir: root
  )
  # auto-await pass: project layouts that don't have an `app/`
  # directory (e.g. a single-file classic Sinatra example with a
  # top-level `app.rb`) are still valid — feed the lone file to
  # auto-await so its `db.execute` / `kv.get` / etc. still get
  # `__await__` inserted.
  if root.join('app').directory?
    run!(
      [
        'ruby', CloudflareWorkersBuild.exe_path('auto-await').to_s,
        '--input', 'app',
        '--output', 'build/auto_await/app'
      ],
      chdir: root
    )
  elsif root.join('app.rb').file?
    run!(
      [
        'ruby', CloudflareWorkersBuild.exe_path('auto-await').to_s,
        '--input', 'app.rb',
        '--output', 'build/auto_await/app.rb'
      ],
      chdir: root
    )
  else
    warn 'homura build: no app/ directory or top-level app.rb — skipping auto-await'
  end

  opal_in = Pathname(resolve_opal_input(root, options[:opal_input]))
  opal_out = Pathname(options[:opal_output])
  opal_in = root.join(opal_in) unless opal_in.absolute?
  opal_out = root.join(opal_out) unless opal_out.absolute?
  prepared_in, temp_input = prepare_opal_input(root, opal_in)
  begin
    run_opal_standalone!(root, prepared_in, opal_out.relative_path_from(root).to_s,
                         with_db: options[:with_db])
  ensure
    FileUtils.rm_f(temp_input) if temp_input
  end
end

patch_rel = Pathname(patch_target)
patch_rel = root.join(patch_rel) unless patch_rel.absolute?
run!(
  [
    'node',
    CloudflareWorkersBuild.runtime_dir.join('patch-opal-evals.mjs').to_s,
    patch_rel.relative_path_from(root).to_s
  ],
  chdir: root
)

write_entrypoint!(
  root,
  options[:entrypoint_out],
  setup: options[:setup_import],
  bundle: options[:bundle_import],
  worker_mod: options[:worker_module_import]
)

$stderr.puts 'homura build: ok'
